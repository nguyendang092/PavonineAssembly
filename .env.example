# ImgBB (tùy chọn — dùng khi gọi POST /api/images/upload)
IMGBB_API_KEY=

# Firebase Web API key — xác thực Bearer token trên API upload
# (cùng giá trị apiKey trong src/services/firebase.js)
FIREBASE_API_KEY=

# Dev: bỏ qua xác thực token (chỉ local)
# IMAGE_UPLOAD_SKIP_AUTH=1

# Server proxy (npm run server)
# SERVER_PORT=8787
# SERVER_HOST=0.0.0.0

# Client build (tùy chọn)
# VITE_IMAGE_UPLOAD_STRATEGY=firebase-first
# VITE_IMAGE_UPLOAD_API_URL=https://your-api-host
